{
  "name": "bibletype",
  "type": "module",
  "private": true,
  "scripts": {
    "admin:promote": "tsx scripts/promote-admin.ts",
    "build": "NUXT_TELEMETRY_DISABLED=1 nuxt build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "dev": "NUXT_TELEMETRY_DISABLED=1 nuxt dev --port 3100",
    "import:bible": "tsx scripts/import-bible.ts",
    "import:places": "tsx scripts/import-places.ts",
    "lint": "eslint .",
    "generate": "NUXT_TELEMETRY_DISABLED=1 nuxt generate",
    "preview": "NUXT_TELEMETRY_DISABLED=1 nuxt preview --port 3100",
    "postinstall": "nuxt prepare",
    "reindex:places": "tsx scripts/rebuild-verse-place-index.ts",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:unit": "vitest run tests/unit tests/components",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "maplibre-gl": "^5.20.1",
    "nodemailer": "^8.0.2",
    "nuxt": "^4.4.2",
    "pg": "^8.20.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@fontsource-variable/sora": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  }
}
